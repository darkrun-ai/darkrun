# fastlane lanes for the darkrun apps:
#   iOS  (platform :ios) — TestFlight (`beta`), App Store (`release`), and the
#         App Store screenshots (`screenshots`/`upload_screenshots`).
#   macOS (platform :mac) — Mac App Store: `install_signing_macos`, `mac_release`,
#         `certs`, `nuke_certs` (see the `platform :mac` block at the bottom).
#
# darkrun's app is built with Dioxus (`dx`), not Xcode directly — CI runs
# `dx build --platform ios --release` first, which generates the Xcode project
# this Fastfile then signs (fastlane match) and packages (gym) into an .ipa.
# Screenshots don't use `capture_screenshots` (XCUITest); they're captured
# externally and framed with `frameit` — see the screenshots lanes below.
#
# CI auth uses an App Store Connect API key (no Apple ID 2FA); signing uses
# `match` (certs in a private git repo). Required env / GitHub secrets:
#   ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_P8   — App Store Connect API key (.p8 body)
#   MATCH_GIT_URL, MATCH_PASSWORD           — the match certs repo + passphrase
#   MATCH_GIT_BASIC_AUTHORIZATION           — base64 "user:token" to read that repo
# One-time, locally: `bundle exec fastlane match appstore` populates the repo.

default_platform(:ios)

# App Store Connect API key for auth (TestFlight + deliver), from CI secrets.
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: ENV.fetch("ASC_KEY_P8"),
    is_key_content_base64: false,
    in_house: false,
  )
end

APP_ID = "ai.darkrun.app"

# The changelog every main-push (release-candidate) TestFlight build carries:
# the in-dev version, the monotonic build number, and the commit, so a tester can
# tell RCs apart at a glance. Shared by the iOS and macOS beta lanes so both
# platforms label builds identically.
def rc_changelog
  sha = (ENV["GITHUB_SHA"] || "")[0, 7]
  ver = ENV["DARKRUN_MARKETING_VERSION"]
  build = ENV["DARKRUN_BUILD_NUMBER"]
  tag = [ver && "v#{ver}", build && "build #{build}"].compact.join(" \u{b7} ")
  ["Release candidate", tag.empty? ? nil : "(#{tag})",
   sha.empty? ? nil : "\u{b7} #{sha}", "off main."].compact.join(" ")
end

# A re-run on the SAME commit re-uploads the same CFBundleVersion, which App
# Store Connect rejects as a duplicate. That means the lane's goal (the build is
# in TestFlight) is already met, not a failure. Only a DIFFERENT error is real.
def tolerate_duplicate_build
  yield
rescue => e
  raise unless e.message =~ /bundle version must be higher|already been used|DUPLICATE/i
  UI.important("TestFlight build already in App Store Connect (this commit was uploaded before); nothing to re-upload.")
end

platform :ios do
  # Sign + package the dx-generated Xcode project into an App Store .ipa. Assumes
  # `dx build --platform ios --release` already ran (CI does this first). `match`
  # is readonly here — CI never mints certs; run `fastlane match appstore` once
  # locally to populate the repo.
  # Install the App Store signing identity (cert + profile) read-only, so the
  # subsequent dx build / codesign uses them. dx emits a built `.app` (not an
  # Xcode project), so packaging.sh signs that `.app` into the `.ipa` — there's
  # no `gym`/`build_app` step. Run this BEFORE the build.
  lane :install_signing do
    # On CI, create an unlocked temporary keychain + add it to the search list.
    # Without this, codesign/match block on a keychain UI prompt that never comes
    # on a headless runner (the build hangs). No-op off CI. The keychain persists
    # for later steps (dx build, then the codesign in package-ios-ipa.sh).
    setup_ci
    sync_code_signing(
      type: "appstore",
      app_identifier: APP_ID,
      api_key: asc_api_key,
      readonly: true,
    )
  end

  desc "TestFlight upload. CI builds + signs the .ipa first (path in DARKRUN_IPA)."
  lane :beta do
    tolerate_duplicate_build do
      upload_to_testflight(
        api_key: asc_api_key,
        app_identifier: APP_ID,
        app_platform: "ios", # pilot's option name; else it prompts + dies in CI
        ipa: ENV.fetch("DARKRUN_IPA"),
        skip_waiting_for_build_processing: true,
        distribute_external: false,
        changelog: rc_changelog,
      )
    end
  end

  desc "App Store upload (no auto-submit). CI builds + signs the .ipa first."
  lane :release do
    # ios-testflight fires on the push to main and uploads this exact build
    # (CFBundleVersion = git rev-list --count) BEFORE the tag-triggered release
    # runs on the SAME release commit, so the GA binary is normally already in
    # App Store Connect. A duplicate-version 409 here therefore means this lane's
    # goal (the GA build is AVAILABLE in ASC) is already met, not a failure. Only
    # a DIFFERENT error is real and re-raised.
    begin
      upload_to_app_store(
        api_key: asc_api_key,
        app_identifier: APP_ID,
        platform: "ios", # else deliver prompts for it and dies in non-interactive CI
        ipa: ENV.fetch("DARKRUN_IPA"),
        submit_for_review: false,
        automatic_release: false,
        force: true, # skip the HTML metadata-preview confirmation (non-interactive)
        skip_screenshots: true, # screenshots have their own lane
        # Binary only, like mac_release: the listing + submission stay a human step
        # in App Store Connect; this lane just makes the GA build available there.
        skip_metadata: true,
        precheck_include_in_app_purchases: false,
        run_precheck_before_submit: false,
      )
    rescue => e
      raise unless e.message =~ /bundle version must be higher|already been used|DUPLICATE/i
      UI.important("iOS build already in App Store Connect (ios-testflight uploaded it on the release commit); nothing to re-upload.")
    end
  end

  desc "One-time setup: create the App Store distribution cert + provisioning"
  desc "profile and store them (encrypted) in the match repo. Run by"
  desc "fastlane/bootstrap-ios-signing.sh; needs the ASC API key + MATCH_* env."
  lane :certs do
    sync_code_signing(
      type: "appstore",
      app_identifier: APP_ID,
      api_key: asc_api_key,
      readonly: false, # create + push if absent (the only lane that may write)
      # force-regenerate the PROFILE (not the cert) so newly-enabled App ID
      # capabilities — App Group, Associated Domains — land in it. Profiles are
      # immutable snapshots; without this, an existing profile is reused as-is.
      force: true,
    )
  end

  desc "DANGER: revoke the account's App Store distribution cert + profiles and"
  desc "clear them from the match repo (they're recreated on the next `certs`"
  desc "run). Distribution certs are ACCOUNT-WIDE, so only when darkrun is the"
  desc "sole app. Run via MATCH_NUKE=1 ./fastlane/bootstrap-ios-signing.sh."
  lane :nuke_certs do
    match_nuke(
      type: "appstore",
      app_identifier: APP_ID,
      api_key: asc_api_key,
      skip_confirmation: true,
    )
  end

  desc "Frame raw screenshots with device bezels + dark-brand captions"
  desc "Input:  fastlane/screenshots/<locale>/*.png  (raw, named <device>-<screen>.png)"
  desc "Output: …_framed.png beside each, ready for `deliver`"
  lane :screenshots do
    # One-time per machine: pull the device frame images frameit composites.
    #   bundle exec fastlane frameit download_frames
    # (Not run here — it's a large binary download, cached under ~/.frameit.)
    frameit(
      path: "./fastlane/screenshots",
      use_platform: "IOS"
    )
    UI.success("Framed screenshots written. Review them, then `fastlane upload_screenshots`.")
  end

  desc "Upload the framed screenshots to App Store Connect (no binary, no submit)"
  lane :upload_screenshots do
    deliver(
      app_identifier: "ai.darkrun.app",
      screenshots_path: "./fastlane/screenshots",
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force: true
    )
  end
end

# Mac App Store (MAS) lanes. Mirror the iOS lanes, adapted to macOS: the dx-built
# `.app` is signed + wrapped into an installer `.pkg` by package-macos-pkg.sh,
# then uploaded to App Store Connect. Two signing types instead of one — a Mac
# App Distribution cert (signs the app) AND a Mac Installer Distribution cert
# (signs the .pkg) — both pulled from the SAME match repo as iOS. The Mac App
# Store provisioning profile carries the App Group group.ai.darkrun + Associated
# Domains capabilities (see fastlane/darkrun-mac.entitlements). Same ASC API key,
# same APP_ID, same MATCH_* secrets. One-time, locally:
# `MATCH_PASSWORD=<iOS passphrase> ./fastlane/bootstrap-macos-signing.sh`.
platform :mac do
  # Install the Mac App Store signing identities (the app-distribution cert, the
  # installer cert, and the provisioning profile) read-only, so the subsequent
  # codesign / productbuild in package-macos-pkg.sh uses them. dx emits a built
  # `.app` (not an Xcode project), so there's no `gym`/`build_app` step — run
  # this BEFORE the build. setup_ci creates an unlocked temporary keychain on CI
  # (no-op off CI) so codesign/match don't block on a keychain UI prompt that
  # never comes on a headless runner.
  lane :install_signing_macos do
    setup_ci
    sync_code_signing(
      type: "mac_installer_distribution",
      platform: "macos",
      app_identifier: APP_ID,
      api_key: asc_api_key,
      readonly: true,
      # The installer type is a CERTIFICATE only — it has no provisioning
      # profile, so don't look for one (else match fails "No matching
      # provisioning profiles found for ...mac_installer_distribution").
      skip_provisioning_profiles: true,
      # The Mac Installer Distribution cert is NOT part of the unified "Apple
      # Distribution" scheme, so match's default generate_apple_certs:true wrongly
      # installs the app cert here. false → the legacy installer cert (the one
      # productbuild needs to sign the .pkg).
      generate_apple_certs: false,
    )
    sync_code_signing(
      type: "appstore",
      platform: "macos",
      app_identifier: APP_ID,
      api_key: asc_api_key,
      readonly: true,
    )
  end

  desc "TestFlight upload (macOS). CI builds + signs the .pkg first (path in"
  desc "DARKRUN_PKG). This is the RC path every main push takes."
  #
  # macOS needs its OWN pilot lane, exactly like iOS `beta`. Pushing a main build
  # through `mac_release` (deliver) uploads it as an App Store SUBMISSION
  # candidate, which only INCIDENTALLY shows up in TestFlight: builds 864 and 866
  # surfaced that way, 868 processed and never became "available to test" on
  # macOS (Apple sent no failure either), so the Mac testers stayed a build
  # behind with no signal. pilot puts the build in TestFlight explicitly.
  lane :mac_beta do
    tolerate_duplicate_build do
      upload_to_testflight(
        api_key: asc_api_key,
        app_identifier: APP_ID,
        app_platform: "osx", # pilot's macOS platform; else it prompts + dies in CI
        pkg: ENV.fetch("DARKRUN_PKG"),
        skip_waiting_for_build_processing: true,
        distribute_external: false,
        changelog: rc_changelog,
      )
    end
  end

  desc "Mac App Store upload (no auto-submit). CI builds + signs the .pkg first"
  desc "(path in DARKRUN_PKG)."
  lane :mac_release do
    upload_to_app_store(
      api_key: asc_api_key,
      app_identifier: APP_ID,
      platform: "osx", # else deliver prompts for it and dies in non-interactive CI
      pkg: ENV.fetch("DARKRUN_PKG"),
      submit_for_review: false,
      automatic_release: false,
      force: true, # skip the HTML metadata-preview confirmation (non-interactive)
      skip_screenshots: true, # screenshots have their own lane
      # Upload the BINARY only. deliver's first-version metadata upload throws
      # "No data" from App Store Connect (fastlane#20538) when there's no
      # ./fastlane/metadata tree for macOS; metadata is curated by hand in ASC
      # ("Prepare for Submission"), so skip it here and just push the .pkg.
      skip_metadata: true,
      skip_app_version_update: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
    )
  end

  desc "One-time setup: create the Mac App Distribution cert, Mac Installer"
  desc "Distribution cert, and the Mac App Store provisioning profile, and store"
  desc "them (encrypted) in the match repo. Run by"
  desc "fastlane/bootstrap-macos-signing.sh; needs the ASC API key + MATCH_* env."
  lane :certs do
    sync_code_signing(
      type: "mac_installer_distribution",
      platform: "macos",
      app_identifier: APP_ID,
      api_key: asc_api_key,
      readonly: false, # create + push if absent
      skip_provisioning_profiles: true, # installer = cert only, no profile
      # false → the legacy Mac Installer Distribution cert (productbuild needs it);
      # the default true installs the app "Apple Distribution" cert by mistake.
      generate_apple_certs: false,
    )
    sync_code_signing(
      type: "appstore",
      platform: "macos",
      app_identifier: APP_ID,
      api_key: asc_api_key,
      readonly: false, # create + push if absent
      # force-regenerate the PROFILE so the App Group + Associated Domains
      # capabilities (newly enabled on the App ID) land in it (see ios :certs).
      force: true,
    )
  end

  desc "DANGER: revoke the account's Mac App Store distribution + installer certs"
  desc "and profiles and clear them from the match repo (recreated on the next"
  desc "`mac certs` run). Distribution certs are ACCOUNT-WIDE, so only when"
  desc "darkrun is the sole app. Run via MATCH_NUKE=1 ./fastlane/bootstrap-macos-signing.sh."
  lane :nuke_certs do
    match_nuke(
      type: "mac_installer_distribution",
      platform: "macos",
      app_identifier: APP_ID,
      api_key: asc_api_key,
      skip_confirmation: true,
    )
    match_nuke(
      type: "appstore",
      platform: "macos",
      app_identifier: APP_ID,
      api_key: asc_api_key,
      skip_confirmation: true,
    )
  end
end
