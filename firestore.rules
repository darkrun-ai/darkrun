rules_version = '2';

// darkrun Firestore security rules.
//
// Firestore here is NOT a mirror of run state — run state lives on the host (the
// agent's live MCP session, reached through the relay tunnel) or in the git repo
// (read-only when no session is live). These rules describe only what code
// actually reads and writes today:
//
//   - accounts + their linked provider identities,
//   - a top-level `devices` collection of FCM push registrations, and
//   - a top-level `relayBroker` collection of parked login tokens (nonce-keyed).
//
// Trust model: every signed-in Firebase Auth user's `uid` IS the account id.
// Device docs are written by the relay's service account (see
// web/server/src/firestore.rs), which bypasses these rules; clients never write
// Firestore directly — device registration goes through the relay's
// authenticated `POST /devices`. So clients get read-only, owner-scoped access.

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(aid) {
      return request.auth != null && request.auth.uid == aid;
    }

    // ── Accounts + linked identities ────────────────────────────────────────
    // An account and its linked provider identities are readable only by their
    // owner. Writes are brokered server-side (admin), never by the client.
    match /accounts/{accountId} {
      allow read: if isOwner(accountId);
      allow write: if false; // engine/admin only

      match /identities/{identityId} {
        allow read: if isOwner(accountId);
        allow write: if false; // linking is admin-brokered
      }
    }

    // ── Push devices ────────────────────────────────────────────────────────
    // The relay persists one document per FCM registration, keyed by the token's
    // hash, holding { account, token, platform } (web/server/src/firestore.rs).
    // The server writes these with a service account (rules bypassed); a signed-in
    // client may read only its OWN device docs, and no client writes here.
    match /devices/{deviceId} {
      allow read: if isOwner(resource.data.account);
      allow write: if false; // relay service-account only
    }

    // ── Relay-token broker ──────────────────────────────────────────────────
    // The relay parks one document per login nonce, holding { token, expiresAt },
    // so deposit/claim scale across Cloud Run instances (web/server/src/relay_broker.rs).
    // The service account reads and writes these (rules bypassed); the parked
    // token is a bearer secret the browser deposits and the CLI claims over the
    // authenticated HTTP endpoints, never through Firestore. So NO client may read
    // or write here — unlike /devices, not even owner reads (a nonce has no owner).
    match /relayBroker/{nonce} {
      allow read, write: if false; // relay service-account only
    }

    // ── Session registry ────────────────────────────────────────────────────
    // The relay records one document per LIVE session, holding
    // { ownerAccountId, hostInstance, expiresAt }, so single-host-per-session and
    // owner authz are correct across Cloud Run instances (web/server/src/relay_registry.rs).
    // The service account reads and writes these (rules bypassed); a client reaches
    // a session only through the relay's authenticated tunnel endpoints, never
    // Firestore. So NO client may read or write here — like /relayBroker, and
    // matching SCHEMA.md's "reached through the relay, not mirrored" model.
    match /sessions/{sessionId} {
      allow read, write: if false; // relay service-account only
    }
  }
}
