rules_version = '2';

// darkrun Firestore security rules.
//
// Firestore here is NOT a mirror of run state — run state lives on the host (the
// agent's live MCP session, read through a tunnel) or in the git repo (read-only
// when no session is live). Firestore holds only: accounts + linked identities +
// push devices, and a SESSION REGISTRY (liveness + how to reach a live host) with
// its tunnel-signaling subcollection.
//
// Trust model: every writer is a signed-in Firebase Auth user; its `uid` is the
// account id. The HOST runs on the user's machine signed in as that account, so
// it writes its OWN session records directly (no service account). For now a
// session is single-owner (your own devices); multi-party "channels" come later
// and will widen the session read/signal scope.

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(aid) {
      return request.auth != null && request.auth.uid == aid;
    }

    // The account that owns a session doc.
    function sessionOwner(sessionId) {
      return get(/databases/$(database)/documents/sessions/$(sessionId)).data.ownerAccountId;
    }

    // ── Accounts + linked identities + push devices ─────────────────────────
    match /accounts/{accountId} {
      allow read: if isOwner(accountId);
      allow write: if false; // engine/admin only

      match /identities/{identityId} {
        allow read: if isOwner(accountId);
        allow write: if false; // linking is admin-brokered
      }

      match /devices/{deviceId} {
        allow read: if isOwner(accountId);
        allow write: if isOwner(accountId); // client registers its own FCM token
      }
    }

    // ── Session registry: live agent MCP sessions ───────────────────────────
    // A host registers + heartbeats its OWN sessions; clients of the same account
    // read them to discover what's live and how to tunnel in. No run state here —
    // just liveness + reachability + a notification hint.
    match /sessions/{sessionId} {
      allow read: if isOwner(resource.data.ownerAccountId);
      // Host writes its own session record (ownerAccountId must be itself).
      allow create: if isOwner(request.resource.data.ownerAccountId);
      allow update, delete: if isOwner(resource.data.ownerAccountId);

      // Tunnel handshake — both host and client (same owner for now) exchange
      // signaling payloads to establish the tunnel. Widens with channels later.
      match /signals/{signalId} {
        allow read, write: if isOwner(sessionOwner(sessionId));
      }
    }
  }
}
