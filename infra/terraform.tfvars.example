# Copy to terraform.tfvars (gitignored) and adjust. NOTE: there are NO secrets
# here by design. The OAuth client ids/secrets live in Secret Manager (created by
# bootstrap.sh); the Sentry auth token is the SENTRY_AUTH_TOKEN env / TFC variable.

gcp_project = "darkrun"
gcp_region  = "us-central1"
web_base    = "https://darkrun.ai"
web_domain  = "darkrun.ai"

# Sentry (non-secret slugs only). Set enable_sentry = false to deploy Cloud Run
# before Sentry is set up.
sentry_organization = "your-sentry-org-slug"
sentry_team         = "your-sentry-team-slug"
# enable_sentry = false
